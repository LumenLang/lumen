case: clean: send title with all parts
input: send title "hi" to p
runner: STATEMENT
env:
  var p: player
suggestions: 2
  [#0] send title %title:STRING% to %who:PLAYER%
    confidence: 1.000
    issues: <none>
  [#1] send title %title:STRING% with subtitle %sub:STRING% to %who:PLAYER%
    confidence: 0.400
    issues:
      - missing literal: 'with' (after token 2)
